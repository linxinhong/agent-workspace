{
  "name": "agent-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm --filter daemon dev\" \"pnpm --filter web dev\"",
    "dev:daemon": "pnpm --filter daemon dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter contracts build && pnpm --filter web build",
    "start": "pnpm --filter daemon start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4"
  }
}
