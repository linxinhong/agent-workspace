{
  "id": "kimi-code",
  "name": "Kimi Code",
  "kind": "local-cli",
  "description": "Moonshot Kimi Code CLI — stream-json 模式",
  "command": "kimi",
  "versionArgs": ["--version"],
  "args": ["--print", "--input-format", "stream-json", "--output-format", "stream-json"],
  "inputMode": "stdin-json",
  "outputFormat": "stream-json",
  "timeoutMs": 120000,
  "enabled": true,
  "capabilities": {
    "streaming": true,
    "fileEditing": true,
    "supportsCwd": true,
    "supportsNonInteractive": true
  },
  "permissions": {
    "readProjectFiles": true,
    "writeArtifactFiles": true,
    "writeProjectFiles": true,
    "networkAccess": true,
    "executeCommands": true,
    "requiresApproval": true
  }
}
