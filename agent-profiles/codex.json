{
  "id": "codex",
  "name": "Codex",
  "kind": "local-cli",
  "description": "OpenAI Codex CLI — 本地代码生成 Agent",
  "command": "codex",
  "versionArgs": ["--version"],
  "args": ["exec", "--json"],
  "inputMode": "stdin",
  "outputFormat": "stream-json",
  "timeoutMs": 120000,
  "env": {
    "http_proxy": "http://127.0.0.1:1087",
    "https_proxy": "http://127.0.0.1:1087",
    "ALL_PROXY": "socks5://127.0.0.1:1080"
  },
  "enabled": true,
  "capabilities": {
    "streaming": true,
    "fileEditing": true,
    "supportsCwd": true,
    "supportsEnv": true,
    "supportsNonInteractive": true,
    "ptyRequired": false
  },
  "permissions": {
    "readProjectFiles": true,
    "writeArtifactFiles": true,
    "writeProjectFiles": false,
    "networkAccess": true,
    "executeCommands": true,
    "requiresApproval": true
  }
}
