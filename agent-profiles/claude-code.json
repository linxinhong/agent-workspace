{
  "id": "claude-code",
  "name": "Claude Code",
  "kind": "local-cli",
  "description": "Anthropic Claude Code CLI — stream-json 模式",
  "command": "claude",
  "versionArgs": ["--version"],
  "args": ["--print", "--verbose", "--output-format", "stream-json"],
  "inputMode": "argument",
  "outputFormat": "stream-json",
  "timeoutMs": 120000,
  "enabled": true,
  "capabilities": {
    "streaming": true,
    "fileEditing": true,
    "supportsCwd": true,
    "supportsNonInteractive": true
  }
}
