{
  "id": "hermes-acp",
  "name": "Hermes Agent (ACP)",
  "kind": "acp",
  "description": "Hermes Agent via ACP stdio — 编辑器集成协议",
  "command": "hermes",
  "args": ["acp"],
  "acpEndpoint": "stdio",
  "acpAgentId": "hermes",
  "timeoutMs": 180000,
  "enabled": true,
  "capabilities": {
    "streaming": true,
    "fileEditing": true,
    "supportsCwd": true,
    "supportsNonInteractive": true
  },
  "permissions": {
    "readProjectFiles": true,
    "writeArtifactFiles": true,
    "writeProjectFiles": true,
    "networkAccess": true,
    "executeCommands": true,
    "requiresApproval": false
  }
}
